---
interface Props {
  title: string;
  pubDate: Date;
  description: string;
  tags: string[];
  slug: string;
}

const { title, pubDate, description, tags, slug } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a
  href={`/blog/${slug}`}
  class="block group"
  data-tags={tags.join(",")}
>
  <div class="bg-[#1414149c] border border-[var(--white-icon-tr)] rounded-2xl p-6 transition-all duration-300 hover:border-[var(--sec)] hover:bg-[#1a1a1a]">
    <time class="text-sm text-[var(--white-icon)]">{formattedDate}</time>
    <h4 class="text-xl font-semibold text-[var(--white)] mt-2 group-hover:text-[var(--sec)] transition-colors duration-300">
      {title}
    </h4>
    <p class="text-[var(--white-icon)] mt-2 line-clamp-2">{description}</p>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs px-2 py-1 rounded-full bg-[var(--white-icon-tr)] text-[var(--white-icon)]">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>
